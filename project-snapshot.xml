/* bal24 WorkFlow v2 — 글로벌 스타일 */

/* Pretendard 폰트 CDN */
@import url('https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css');

@tailwind base;
@tailwind components;
@tailwind utilities;

/* ─────────────────────────────────────────────
   디자인 토큰 (Skywork 지시서 v1.1)
   RGB 채널 분리 — Tailwind opacity modifier(bg-primary/10) 호환
   ───────────────────────────────────────────── */
:root {
  --color-primary:   124 58 237;   /* #7C3AED */
  --color-secondary: 249 115 22;   /* #F97316 */
  --color-accent:    6 182 212;    /* #06B6D4 */
  --color-success:   16 185 129;   /* #10B981 */
  --color-warning:   245 158 11;   /* #F59E0B */
  --color-danger:    239 68 68;    /* #EF4444 */
  --color-bg:        248 247 255;  /* #F8F7FF */
  --color-card:      255 255 255;  /* #FFFFFF */
  --color-sidebar:   30 27 75;     /* #1E1B4B */
  --color-text:      30 27 75;     /* #1E1B4B */
  --color-muted:     100 116 139;  /* #64748B */
  --radius-card:     16px;
  --radius-btn:      10px;
  --shadow-card:     0 4px 16px rgba(124, 58, 237, 0.08);
}

/* ─────────────────────────────────────────────
   기본 스타일
   ───────────────────────────────────────────── */
@layer base {
  html {
    font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, 'Noto Sans KR', sans-serif;
    color: var(--color-text);
  }

  body {
    background-color: var(--color-bg);
    margin: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  *, *::before, *::after {
    box-sizing: border-box;
  }
}

/* ─────────────────────────────────────────────
   컴포넌트 클래스
   ───────────────────────────────────────────── */
@layer components {
  /* 카드 */
  .v2-card {
    @apply bg-card rounded-card border border-[#EDE9FE] shadow-card;
  }

  /* 버튼 — 기본 호버: scale(1.02) + 0.2s ease */
  .v2-btn {
    @apply rounded-btn px-4 py-2 font-semibold transition-transform duration-200 ease-out;
  }
  .v2-btn:hover {
    transform: scale(1.02);
  }
  .v2-btn-primary {
    @apply v2-btn bg-primary text-white hover:bg-primary/90;
  }
  .v2-btn-secondary {
    @apply v2-btn bg-white text-text border border-[#EDE9FE] hover:bg-[#F8F7FF];
  }
  .v2-btn-danger {
    @apply v2-btn bg-danger text-white hover:bg-danger/90;
  }

  /* 상태 배지 — 프로젝트 */
  .badge-proposal { @apply bg-gray-100 text-gray-700 px-2 py-1 rounded-md text-xs font-semibold; }
  .badge-active   { @apply bg-primary/10 text-primary px-2 py-1 rounded-md text-xs font-semibold; }
  .badge-billing  { @apply bg-secondary/10 text-secondary px-2 py-1 rounded-md text-xs font-semibold; }
  .badge-closed   { @apply bg-success/10 text-success px-2 py-1 rounded-md text-xs font-semibold; }

  /* 상태 배지 — 태스크 */
  .badge-task-recognize { @apply bg-gray-100 text-gray-700 px-2 py-1 rounded-md text-xs font-semibold; }
  .badge-task-execute   { @apply bg-primary/10 text-primary px-2 py-1 rounded-md text-xs font-semibold; }
  .badge-task-review    { @apply bg-secondary/10 text-secondary px-2 py-1 rounded-md text-xs font-semibold; }
  .badge-task-done      { @apply bg-success/10 text-success px-2 py-1 rounded-md text-xs font-semibold; }

  /* 상태 배지 — 정산 */
  .badge-unpaid    { @apply bg-gray-100 text-gray-700 px-2 py-1 rounded-md text-xs font-semibold; }
  .badge-partial   { @apply bg-secondary/10 text-secondary px-2 py-1 rounded-md text-xs font-semibold; }
  .badge-paid      { @apply bg-success/10 text-success px-2 py-1 rounded-md text-xs font-semibold; }
}
