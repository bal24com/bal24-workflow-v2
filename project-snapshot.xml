                          <ExternalLink size={10} aria-hidden="true" />
                          영수증
                        </a>
                      ) : e.docs_submitted ? (
                        <span className="inline-flex items-center gap-0.5 text-[10px] text-emerald-700">
                          <FileCheck2 size={10} aria-hidden="true" />
                          서류 완료
                        </span>
                      ) : (
                        <span className="text-slate-300">-</span>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </>
      )}
    </section>
  );
}
