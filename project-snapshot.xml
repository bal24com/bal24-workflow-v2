];

// FINANCE 전용 사이드바 (3그룹 — 홈/재무/도구)
const FINANCE_SECTIONS: MenuSection[] = [
  {
    heading: '홈',
    items: [
      { to: '/home',     label: '대시보드', Icon: LayoutDashboard },
      { to: '/schedule', label: '일정',     Icon: CalendarDays },
    ],
  },
  {
    heading: '재무',
    items: [
