CREATE POLICY "public_read_by_token" ON public.program_share
  FOR SELECT USING (true);

-- 관리자 (인증) 전체 권한
CREATE POLICY "auth_all" ON public.program_share
  FOR ALL TO authenticated USING (true) WITH CHECK (true);
```

