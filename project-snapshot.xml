<file path="src/pages/projects/detail/OverviewTab.tsx">
// bal24 v2 — 프로젝트 상세 · 개요 탭 (V7 → V2 이식)
// 3열 그리드: 좌(재무·참여자·이벤트) / 중앙(기존 기본정보·설명) / 우(활동·다음행동·빠른액션)

import { Badge, Card, CardContent, CardHeader, CardTitle } from '../../../components/ui';
