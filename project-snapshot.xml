          <div className="px-4 py-2 text-xs text-slate-500 bg-violet-50/40 border-b border-slate-100">
            합계: <span className="font-bold text-violet-700">{formatKRW(totalIncome)}</span>
          </div>
          {income.length === 0 ? (
