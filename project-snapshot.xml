              </div>
              <button
                type="button"
                onClick={() => onChange(files.filter((_, idx) => idx !== i))}
                disabled={disabled}
                className="p-1 rounded text-slate-400 hover:text-danger hover:bg-danger/5"
                aria-label={`${f.name} 제거`}
              >
                <Trash2 size={12} />
              </button>
            </li>
          ))}
        </ul>
      )}
      {errorMsg && (
