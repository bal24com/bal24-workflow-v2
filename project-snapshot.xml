                            </button>
                          </div>
                        </li>
                      );
                    })}
                  </ul>
                </div>
              ))
            )}
          </nav>
        </aside>

        {/* 우측 채팅 */}
        <section className="flex flex-col min-w-0">
          <AiChatWindow
            conversationId={activeId}
            userId={userId}
            onConversationCreated={handleConversationCreated}
          />
        </section>
      </div>
    </div>
  );
}
