      groups.get(key)!.push(c);
    }
    return Array.from(groups.entries());
  }, [conversations]);

  if (!userId) {
    return (
      <div className="rounded-2xl border border-violet-100 bg-white p-12 text-center text-sm text-slate-500">
        로그인 정보를 불러오는 중이에요.
      </div>
    );
