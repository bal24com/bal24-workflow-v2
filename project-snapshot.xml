      // STEP-SIDEBAR-PROGRAM-RESTORE — 프로젝트 하위 메뉴로 들여쓰기 표시
      { to: '/programs',   label: '프로그램', Icon: BookOpen, nested: true },
      { to: '/consortium', label: '컨소시엄', Icon: Building2 },
