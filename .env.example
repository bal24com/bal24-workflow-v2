# bal24 WorkFlow v2 — 환경변수 예시
# 실제 .env 파일에 값 채워서 사용 (.env는 .gitignore에 포함되어 git에 올라가지 않음)

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# AI(Anthropic) 키는 Supabase Edge Function 환경변수로만 관리됩니다.
# 절대 클라이언트(.env / VITE_*)에 두지 마세요 — 브라우저 번들에 노출되어 도용 위험!
# Supabase Dashboard → Edge Functions → Secrets → ANTHROPIC_API_KEY 추가
