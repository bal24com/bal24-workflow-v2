# bal24 WorkFlow v2 — 환경변수 예시
# 실제 .env 파일에 값 채워서 사용 (.env는 .gitignore에 포함되어 git에 올라가지 않음)

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Claude API 키는 Supabase Edge Function 환경변수로만 사용 (프론트엔드 노출 금지)
# Supabase Dashboard → Edge Functions → Secrets → ANTHROPIC_API_KEY 추가
