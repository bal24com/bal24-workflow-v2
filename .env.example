# bal24 WorkFlow v2 — 환경변수 예시
# 실제 .env 파일에 값 채워서 사용 (.env는 .gitignore에 포함되어 git에 올라가지 않음)

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# [개발용 임시] 명함 인식(STEP 10-B)에 사용 — 브라우저 번들에 노출됨, 사내/테스트 한정.
# 프로덕션은 Supabase Edge Function으로 옮길 것.
VITE_CLAUDE_API_KEY=your-anthropic-api-key

# [권장 / 향후] Edge Function 환경변수에 별도 보관 — 외부 배포 시
# Supabase Dashboard → Edge Functions → Secrets → ANTHROPIC_API_KEY 추가
